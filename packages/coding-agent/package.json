{
	"type": "module",
	"name": "@gajae-code/coding-agent",
	"version": "0.10.0",
	"description": "Gajae Code CLI with read, bash, edit, write tools and session management",
	"homepage": "https://gajae-code.com",
	"author": "Yeachan-Heo and Gajae Code Contributors",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Yeachan-Heo/gajae-code.git",
		"directory": "packages/coding-agent"
	},
	"bugs": {
		"url": "https://github.com/Yeachan-Heo/gajae-code/issues"
	},
	"keywords": [
		"coding-agent",
		"ai",
		"llm",
		"cli",
		"tui",
		"agent"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"bin": {
		"gjc": "bin/gjc.js"
	},
	"scripts": {
		"build": "bun scripts/build-binary.ts",
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.test.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test",
		"bench:context": "bun run bench/context-optimization.bench.ts",
		"generate-schemas": "bun ../../scripts/generate-json-schemas.ts",
		"check:schemas": "bun ../../scripts/generate-json-schemas.ts --check",
		"fix": "biome check --write --unsafe . && bun run format-prompts && bun run generate-docs-index",
		"fmt": "biome format --write . && bun run format-prompts",
		"format-prompts": "bun scripts/format-prompts.ts",
		"generate-docs-index": "bun scripts/generate-docs-index.ts",
		"prepack": "bun scripts/generate-docs-index.ts",
		"generate-template": "bun scripts/generate-template.ts",
		"install:defaults": "bun src/cli.ts setup defaults",
		"verify:insane-vendor": "bun scripts/verify-insane-vendor.ts"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "catalog:",
		"@babel/parser": "catalog:",
		"@mozilla/readability": "catalog:",
		"@gajae-code/stats": "catalog:",
		"@gajae-code/agent-wire": "catalog:",
		"@gajae-code/agent-core": "catalog:",
		"@gajae-code/ai": "catalog:",
		"@gajae-code/natives": "catalog:",
		"@gajae-code/tui": "catalog:",
		"@gajae-code/utils": "catalog:",
		"@puppeteer/browsers": "catalog:",
		"@types/turndown": "catalog:",
		"@xterm/headless": "catalog:",
		"chalk": "catalog:",
		"diff": "catalog:",
		"fflate": "catalog:",
		"handlebars": "catalog:",
		"linkedom": "catalog:",
		"lru-cache": "catalog:",
		"markit-ai": "catalog:",
		"puppeteer-core": "catalog:",
		"turndown": "catalog:",
		"turndown-plugin-gfm": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"@types/ws": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src",
		"!src/**/*.test.*",
		"bin",
		"scripts",
		"examples",
		"README.md",
		"CHANGELOG.md",
		"vendor",
		"!vendor/insane-search/engine/tests/**",
		"!src/export/html/template.html",
		"!src/export/html/template.css",
		"!src/export/html/template.js"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./sdk": {
			"types": "./src/sdk.ts",
			"import": "./src/sdk.ts"
		},
		"./cli": {
			"types": "./src/cli.ts",
			"import": "./src/cli.ts"
		}
	}
}
