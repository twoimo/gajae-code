{
	"type": "module",
	"name": "@gajae-code/rpc-sdk",
	"version": "0.7.2",
	"description": "Installable TypeScript SDK for the GJC runtime daemon RPC boundary",
	"homepage": "https://gaebal-gajae.dev",
	"author": "Yeachan-Heo",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gajae-ai/gajae-code.git",
		"directory": "packages/rpc-sdk"
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"generate:types": "bun ../../scripts/rpc-sdk/generate-rpc-sdk-types.ts",
		"check:types": "bun ../../scripts/rpc-sdk/generate-rpc-sdk-types.ts --check && tsgo -p tsconfig.json --noEmit",
		"check": "bun run check:types",
		"test": "bun test"
	},
	"dependencies": {},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./codec": {
			"types": "./src/codec.ts",
			"import": "./src/codec.ts"
		},
		"./protocol": {
			"types": "./src/protocol/index.ts",
			"import": "./src/protocol/index.ts"
		},
		"./protocol/*": {
			"types": "./src/protocol/*.ts",
			"import": "./src/protocol/*.ts"
		},
		"./transport/*": {
			"types": "./src/transport/*.ts",
			"import": "./src/transport/*.ts"
		},
		"./auth/*": {
			"types": "./src/auth/*.ts",
			"import": "./src/auth/*.ts"
		},
		"./commands/*": {
			"types": "./src/commands/*.ts",
			"import": "./src/commands/*.ts"
		},
		"./events/*": {
			"types": "./src/events/*.ts",
			"import": "./src/events/*.ts"
		},
		"./primitives/*": {
			"types": "./src/primitives/*.ts",
			"import": "./src/primitives/*.ts"
		},
		"./*.js": "./src/*.ts",
		"./discovery": {
			"types": "./src/discovery.ts",
			"import": "./src/discovery.ts"
		}
	}
}
